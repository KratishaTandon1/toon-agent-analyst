# AgentStudio Deployment Configurations
# Rename this file to .env or .env.local to enable pre-configured live LLM analysis.

# Enable live LLM execution mode by default (true / false)
VITE_USE_LIVE=false

# Default AI provider (gemini / openai)
VITE_API_PROVIDER=gemini

# Default API Key for the selected provider
VITE_API_KEY=
